{
  "manifest_version": 3,
  "name": "Amnesia Ghost Mode",
  "version": "1.0.0",
  "description": "Send URLs and images directly to your local Amnesia instance for privacy scrubbing.",
  "icons": {
    "16": "../public/icon-16.png",
    "32": "../public/icon-32.png",
    "64": "../public/icon-64.png",
    "128": "../public/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["contextMenus", "activeTab", "tabs"],
  "action": {
    "default_title": "Scrub this page"
  }
}
